{
  "name": "arca-invoicing-hex-ddd",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run generate:api && tsx watch src/index.ts",
    "build": "npm run generate:api && tsc -p tsconfig.json",
    "prod": "npm run build && node dist/src/index.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "generate:api": "swagger-typescript-api generate -p ./schemas/openapi.yaml -o ./src/infrastructure/adapters/inbound/http/generated -n api-types.ts --no-client --type-suffix=DTO"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.11",
    "dotenv": "17.4.2",
    "express": "^4.19.2",
    "js-yaml": "4.1.1",
    "mongodb": "^6.5.0",
    "pino": "^9.0.0",
    "pino-http": "^9.0.0",
    "supertest": "7.2.2",
    "swagger-ui-express": "5.0.1",
    "uuid": "14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^22.0.0",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "63.0.0",
    "prettier": "3.8.1",
    "swagger-typescript-api": "13.6.8",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "8.57.0"
  },
  "engines": {
    "node": "22.17.1",
    "npm": "10.9.2"
  }
}
